# -----------------------------------------------------------------------------
# db.local runtime configuration
# -----------------------------------------------------------------------------
# This same file controls local scripts, Docker Compose interpolation, and the
# GitHub Actions deployment wrapper. On the server, GitHub Actions creates and
# preserves a private runtime copy at DEPLOY_ENV_FILE.

# Deployment/server folder locations
# Your server already has these folders:
#   /home/abrar/actions_db.local
#   /home/abrar/backup_db.local
ACTIONS_ROOT=${HOME}/actions_db.local
BACKUP_ROOT=${HOME}/backup_db.local
DEPLOY_ENV_FILE=${HOME}/.config/db.local/runtime.env
ROLLBACK_STATE_DIR=${TMPDIR:-/tmp}/db-local-rollback-${USER:-runner}
COMPOSE_WAIT_TIMEOUT=600
DEPLOY_LOG_TAIL=200
RUN_MINIO_INIT=true

# Compose project, network, containers, and Docker volume names
COMPOSE_PROJECT_NAME=db-local-stack
DB_NETWORK_NAME=db-local-net

POSTGRES_CONTAINER_NAME=db-postgres
PGADMIN_CONTAINER_NAME=db-pgadmin
REDIS_CONTAINER_NAME=db-redis
REDISINSIGHT_CONTAINER_NAME=db-redisinsight
NEO4J_CONTAINER_NAME=db-neo4j
MINIO_CONTAINER_NAME=db-minio
DASHBOARD_CONTAINER_NAME=db-dashboard
MINIO_INIT_CONTAINER_NAME=db-minio-init

POSTGRES_VOLUME_NAME=db-postgres-data
PGADMIN_VOLUME_NAME=db-pgadmin-data
REDIS_VOLUME_NAME=db-redis-data
REDISINSIGHT_VOLUME_NAME=db-redisinsight-data
NEO4J_DATA_VOLUME_NAME=db-neo4j-data
NEO4J_LOGS_VOLUME_NAME=db-neo4j-logs
NEO4J_IMPORT_VOLUME_NAME=db-neo4j-import
NEO4J_PLUGINS_VOLUME_NAME=db-neo4j-plugins
MINIO_VOLUME_NAME=db-minio-data

# Repo-relative folders/files used by Compose and scripts
POSTGRES_INITDB_DIR=./initdb/postgres
DASHBOARD_WWW_DIR=./www
GENERATED_DIR=./generated
PGADMIN_GENERATED_DIR=./generated/pgadmin
PGADMIN_SERVERS_JSON=./generated/pgadmin/servers.json
LOCAL_BACKUP_DIR=./backups
POSTGRES_BACKUP_DIR=./backups/postgres

# -----------------------------------------------------------------------------
# Network binding and ports
# -----------------------------------------------------------------------------
# DB/admin ports.
# Bind to all host interfaces and control access using firewall policy.
# Do not port-forward these raw DB/admin ports from the router to the internet.
DB_HOST_BIND=0.0.0.0

# Static dashboard page.
# Keep this on localhost because host Caddy proxies:
#   https://dbs.home.arpa -> 127.0.0.1:8003
DASHBOARD_HOST_BIND=127.0.0.1
DASHBOARD_PORT=8003

# PostgreSQL + pgvector
POSTGRES_PORT=5432
POSTGRES_DB=langgraph_app
POSTGRES_USER=langgraph_user
POSTGRES_PASSWORD=change_me_postgres_2026

# pgAdmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_2026

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_2026

# RedisInsight
REDISINSIGHT_PORT=5540

# Neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me_neo4j_2026
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512m
NEO4J_HEALTHCHECK_INTERVAL=15s
NEO4J_HEALTHCHECK_TIMEOUT=10s
NEO4J_HEALTHCHECK_RETRIES=40
NEO4J_HEALTHCHECK_START_PERIOD=120s

# MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_2026
MINIO_DEFAULT_BUCKET=langgraph-app
